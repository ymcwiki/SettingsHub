package-as: SettingsHub
enable-nolib-creation: no

# release notes 与包内 changelog 一律用手写 CHANGELOG.md,
# 不让 packager 从 git log 生成(commit 尾注不该出现在发布说明里)
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# 外部库固定版本(可复现打包)。注意:BigWigs packager 对 svn 只支持
# tags/ 目录名(tag:),不支持按 revision 钉(commit: 会被当 tag 拉 tags/<N> 直接 404)。
# 升级流程:改这里的版本号 → 本地同步 Libs/ → 跑无头测试 → 提交。
externals:
  Libs/LibStub:
    url: https://repos.wowace.com/wow/libstub/trunk
    tag: 1.0.3
  Libs/CallbackHandler-1.0:
    url: https://repos.wowace.com/wow/callbackhandler/trunk/CallbackHandler-1.0
    tag: 1.0.9
  Libs/AceDB-3.0:
    url: https://repos.wowace.com/wow/ace3/trunk/AceDB-3.0
    tag: Release-r1390
  Libs/LibSerialize:
    url: https://github.com/rossnichols/LibSerialize
    commit: e89d505
  Libs/LibDeflate:
    # 别钉 1.0.2-release tag:那个旧 tag 缺自身 .pkgmeta 忽略规则,
    # 会把 ldoc HTML 文档和 rockspec 打进插件包(CF 审核拒过)
    url: https://github.com/SafeteeWoW/LibDeflate
    commit: afc3b78

ignore:
  - docs
  - scripts
  - tests
  - requirements-dev.txt
  # LibDeflate 这个 commit 自身 pkgmeta 不忽略 docs/examples,显式剔除
  # (纯 css/config/md,非 HTML+rockspec,CF 能过,但保持包干净)
  - Libs/LibDeflate/docs
  - Libs/LibDeflate/examples
